{
  "name": "openclaw-channel-dmwork",
  "version": "0.5.20",
  "description": "DMWork channel plugin for OpenClaw via WuKongIM WebSocket",
  "main": "dist/index.js",
  "bin": {
    "openclaw-channel-dmwork": "bin/dmwork.js"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "bin",
    "dist",
    "skills",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "prebuild": "rm -rf dist && node -e \"const v=require('./package.json').version; require('fs').writeFileSync('src/version.ts','// Auto-generated by prebuild script. Do not edit manually.\\nexport const PLUGIN_VERSION = \\\"'+v+'\\\";\\n')\"",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "crypto-js": "^4.2.0",
    "curve25519-js": "^0.0.4",
    "md5-typescript": "^1.0.5",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/ws": "^8.5.10",
    "openclaw": "2026.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "id": "openclaw-channel-dmwork",
    "type": "channel",
    "extensions": [
      "dist/index.js"
    ]
  },
  "bundledDependencies": [
    "cos-nodejs-sdk-v5",
    "crypto-js",
    "curve25519-js",
    "md5-typescript"
  ],
  "bundleDependencies": [
    "cos-nodejs-sdk-v5",
    "crypto-js",
    "curve25519-js",
    "md5-typescript"
  ]
}
